# =============================================================================
# LINKEDIN API CONFIGURATION
# =============================================================================
# Get your LinkedIn Access Token from: https://www.linkedin.com/developers/apps
# Required scopes: r_liteprofile, w_member_social, openid, profile

LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here
LINKEDIN_AUTHOR_URN=urn:li:person:YOUR_ID_HERE

# =============================================================================
# AI API CONFIGURATION (Choose one: OpenRouter OR Qwen)
# =============================================================================

# Option 1: OpenRouter (recommended for GPT-4, Claude, etc.)
# Get API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini

# Option 2: Qwen API (Alibaba Cloud)
# Get API key from: https://dashscope.console.aliyun.com/
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL=qwen-plus

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Dry run mode: true = simulate without posting, false = actual posting
DRY_RUN=false

# Post interval in seconds (default: 600 = 10 minutes)
POST_INTERVAL=600

# =============================================================================
# ODOO CONFIGURATION
# =============================================================================
# IMPORTANT: Keep these secure! Change default passwords in production!

# Database Configuration
ODOO_DB_NAME=odoo_db

# Odoo Admin Password (used for database manager)
ODOO_ADMIN_PASSWORD=change_this_password

# PostgreSQL Credentials
POSTGRES_USER=odoo
POSTGRES_PASSWORD=change_this_secure_password

# Odoo Connection Settings
ODOO_URL=http://localhost:8069
ODOO_DB=ai_employee_db
ODOO_USERNAME=admin
ODOO_PASSWORD=change_this_password

# =============================================================================
# EMAIL CONFIGURATION (for email_mcp_server.js)
# =============================================================================
# Get App Password: https://myaccount.google.com/apppasswords
# 1. Enable 2FA on your Google Account
# 2. Generate an App Password for "Mail"
# 3. Use the 16-character password here (no spaces)

GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# =============================================================================
# META (FACEBOOK/INSTAGRAM) CONFIGURATION
# =============================================================================
# Get tokens from: https://developers.facebook.com/apps
# Required permissions: instagram_basic, instagram_content_publish, pages_read_engagement

META_ACCESS_TOKEN=your_meta_access_token_here
META_PAGE_ID=your_facebook_page_id_here
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id_here

# =============================================================================
# TWITTER/X CONFIGURATION
# =============================================================================
# Get keys from: https://developer.twitter.com/en/portal/dashboard
# Required: Twitter Developer Account + Project

TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_SECRET=your_twitter_access_secret_here
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# =============================================================================
# DIRECTORY PATHS (Optional - defaults to project root subdirs)
# =============================================================================
# PENDING_APPROVAL_DIR=AI_Employee_Vault/Pending_Approval
# APPROVED_DIR=AI_Employee_Vault/Approved
# DONE_DIR=AI_Employee_Vault/Done
# LOGS_DIR=AI_Employee_Vault/Logs

# =============================================================================
# SECURITY NOTES
# =============================================================================
# 1. NEVER commit this file with real credentials to git
# 2. This file is in .gitignore - verify before committing
# 3. Rotate API keys regularly (every 90 days recommended)
# 4. Use different credentials for development and production
# 5. Store production secrets in a secure vault (e.g., AWS Secrets Manager)
